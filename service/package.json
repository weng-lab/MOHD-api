{
  "name": "mohd-service",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build ./src/index.ts --target=bun --outdir=./dist",
    "start": "bun dist/index.js",
    "test": "bun test",
    "db:start": "docker compose up -d db",
    "db:stop": "docker compose down",
    "deploy:api": "gcloud run deploy mohd-api --source . --region us-east4"
  },
  "dependencies": {
    "@hono/graphql-server": "^0.7.0",
    "@hono/zod-validator": "^0.7.6",
    "graphql": "^16.12.0",
    "hono": "^4.11.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
